{
  "name": "lumina",
  "version": "1.2.5",
  "description": "Lumina — автоматическая смена обоев при переключении светлой/тёмной темы Windows. Интерфейс в стиле GNOME Adwaita.",
  "main": "main.js",
  "author": "alexv",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test/playlist.test.js && node test/library.test.js && node test/schedule.test.js && node test/justified-layout.test.js && node test/wallhaven.test.js && node test/config.test.js && node test/tray.test.js && node test/wallpaper-host.test.js && node scripts/lint-i18n.js",
    "lint:i18n": "node scripts/lint-i18n.js",
    "package": "node node_modules/@electron/packager/bin/electron-packager.mjs . Lumina --platform=win32 --arch=x64 --icon=assets/icon.ico --out=dist --overwrite --ignore=dist --ignore=\\.claude",
    "installer": "npm run package && node scripts/build-installer.js"
  },
  "build": {
    "appId": "com.alexv.lumina",
    "productName": "Lumina",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lumina"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-winstaller": "^5.4.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
